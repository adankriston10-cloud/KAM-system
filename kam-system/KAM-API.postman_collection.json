            "body": { "mode": "raw", "raw": "{\n  \"account_id\": 1,\n  \"type\": \"email\",\n  \"subject\": \"Proposal for Q3 Expansion\",\n  \"content\": \"Please find our Q3 expansion proposal attached\",\n  \"direction\": \"outbound\",\n  \"date\": \"2024-07-16T09:30\"\n}" },
            "url": { "raw": "{{baseUrl}}/engagement/communications", "host": ["{{baseUrl}}"], "path": ["engagement", "communications"] }
          }
        },
        {
