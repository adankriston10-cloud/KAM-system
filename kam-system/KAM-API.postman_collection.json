          }
        },
        {
          "name": "Generate Invoice",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"account_id\": 1,\n  \"amount\": 100000,\n  \"tax_rate\": 18,\n  \"due_date\": \"2024-08-01\",\n  \"notes\": \"July 2024 invoice\"\n}" },
            "url": { "raw": "{{baseUrl}}/revenue/invoices", "host": ["{{baseUrl}}"], "path": ["revenue", "invoices"] }
          }
        },
        {
          "name": "Mark Invoice Paid",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"paid\",\n  \"paid_date\": \"2024-07-25\"\n}" },
            "url": { "raw": "{{baseUrl}}/revenue/invoices/1", "host": ["{{baseUrl}}"], "path": ["revenue", "invoices", "1"] }
          }
        },
        {
          "name": "Get Overdue Invoices",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/revenue/invoices/overdue", "host": ["{{baseUrl}}"], "path": ["revenue", "invoices", "overdue"] }
          }
        }
      ]
    },
    {
      "name": "Engagement",
